#!/usr/bin/env bash

set -euo pipefail

staged=$(git diff --cached --name-only)

query_changed=false
if printf '%s\n' "$staged" | grep -q '^migrations/'; then
    query_changed=true
fi
if git diff --cached -U0 -- '*.rs' \
    | grep -Eq '^\+.*\bquery(_as|_scalar|_file|_file_as)?!'; then
    query_changed=true
fi

if [ "$query_changed" = true ] && ! printf '%s\n' "$staged" | grep -q '^\.sqlx/'; then
    printf '\033[33m' # yellow
    echo "warning: query-affecting change staged but no .sqlx/ update is staged."
    echo "         If you added/changed a sqlx query or migration, regenerate the"
    echo "         offline cache against an empty DB before pushing:"
    echo "             ./scripts/sqlx-prepare.sh"
    printf '\033[0m'
fi

exit 0
