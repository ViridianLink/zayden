  "query": "SELECT\n    g.user_id,\n    g.coins,\n    g.gems,\n    g.stamina,\n\n    m.miners,\n    m.mines,\n    m.land,\n    m.countries,\n    m.continents,\n    m.planets,\n    m.solar_systems,\n    m.galaxies,\n    m.universes,\n    m.prestige,\n    m.coal,\n    m.iron,\n    m.gold,\n    m.redstone,\n    m.lapis,\n    m.diamonds,\n    m.emeralds,\n    m.tech,\n    m.utility,\n    m.production\nFROM\n    gambling g\nLEFT JOIN gambling_mine m ON g.user_id = m.user_id\nWHERE\n    g.user_id = $1;\n\n",
