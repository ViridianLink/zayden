  "query": "SELECT\n    g.user_id,\n    g.coins,\n    COALESCE(i.quantity, 0) AS quantity\nFROM\n    gambling g\nLEFT JOIN gambling_inventory i\n    ON\n        g.user_id = i.user_id\n        AND i.item_id = $2\nWHERE\n    g.user_id = $1\n\n",
