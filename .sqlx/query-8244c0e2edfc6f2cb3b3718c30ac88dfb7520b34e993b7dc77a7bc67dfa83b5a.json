  "query": "\n            SELECT\n                s.guild_id AS id,\n                COALESCE(t.thread_id, 0) AS \"thread_id!\",\n                s.support_channel_id,\n                s.faq_channel_id\n            FROM support_settings s\n            LEFT JOIN ticket_settings t ON t.guild_id = s.guild_id\n            WHERE s.guild_id = $1\n            ",
