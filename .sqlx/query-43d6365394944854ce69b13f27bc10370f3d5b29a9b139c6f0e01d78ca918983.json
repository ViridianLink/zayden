{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                p.id,\n                p.activity,\n                p.start_time as \"start_time: jiff_sqlx::Timestamp\",\n\n                COALESCE(\n                    (SELECT array_agg(f.user_id) FROM lfg_fireteam f WHERE f.post_id = p.id),\n                    '{}'\n                ) AS \"fireteam!\"\n\n            FROM\n                lfg_posts p\n            JOIN lfg_fireteam f ON p.id = f.post_id\n            WHERE\n                f.user_id = $1\n            ",
