  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                g.user_id,\n                g.coins,\n\n                i.id AS \"item_row_id?\",\n                i.quantity AS \"item_quantity?\"\n            FROM\n                gambling g\n            LEFT JOIN\n                gambling_inventory i ON g.user_id = i.user_id AND i.item_id = $2\n            WHERE\n                g.user_id = $1\n            ",
