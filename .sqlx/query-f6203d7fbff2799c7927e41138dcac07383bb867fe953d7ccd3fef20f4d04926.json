{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                p.owner_id,\n                p.activity,\n                p.start_time as \"start_time: jiff_sqlx::Timestamp\",\n                p.description,\n                p.fireteam_size,\n                u.timezone AS \"timezone?\"\n            FROM\n                lfg_posts AS p\n            LEFT JOIN\n                lfg_user_config AS u ON p.owner_id = u.id\n            WHERE\n                p.id = $1\n            ",
